import rclpy
from rclpy.node import Node
from rclpy.qos import ReliabilityPolicy, QoSProfile
from geometry_msgs.msg import Twist
import cv2
from cv_bridge import CvBridge
from sensor_msgs.msg import CompressedImage
from std_msgs.msg import String
import numpy as np
from robcomp_util.odom import Odom
import time
from robcomp_interfaces.msg import DetectionArray
from robcomp_util.laser import Laser

class SeguidorNode(Node, Odom, Laser):

    def __init__(self):
        super().__init__('seguidor_node')
        Odom.__init__(self)
        Laser.__init__(self)
        self.timer = self.create_timer(0.25, self.control)
        self.start_time = time.time()  # Tempo de início
        self.aruco_detected_time = None
        self.should_turn = False
        self.detected_once = 0
        self.running = True
        self.robot_state = 'centraliza'
        self.state_machine = {
            'para': self.para,
            'centraliza': self.centraliza,
            'segue': self.segue,
            'virar': self.virar,
            'virar_esquerda': self.virar_esquerda,
        }

        self.twist = Twist()
        self.ja_virou = 0
        self.cx = -1
        self.cy = -1
        self.w = 0
        self.kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (5, 5))
        self.bridge = CvBridge()
        self.creepers = {
            'green_13': '',
            'green_32': '',
            'blue_21': '',
            'blue_11': '',
            'bird': None,
            'dog': None,
            'horse': None
        }

        # Subscribers
        self.image_sub = self.create_subscription(
            CompressedImage,
            '/image_raw/compressed',
            self.image_callback,
            QoSProfile(depth=10, reliability=ReliabilityPolicy.BEST_EFFORT))

        self.flag_sub = self.create_subscription(
            String,
            '/vision/image_flag',
            self.flag_callback,
            QoSProfile(depth=10, reliability=ReliabilityPolicy.BEST_EFFORT))

        self.aruco_subscriber = self.create_subscription(
            DetectionArray,
            '/aruco_detection',
            self.aruco_callback, 10)

        self.creeper_subscriber = self.create_subscription(
            DetectionArray,
            '/creeper',
            self.creeper_callback, 10)

        self.mobile_net_subscriber = self.create_subscription(
            DetectionArray,
            '/mobilenet_detection',
            self.mobile_net_callback, 10)

        # Publishers
        self.cmd_vel_pub = self.create_publisher(Twist, 'cmd_vel', 10)

    def flag_callback(self, msg):
        self.running = bool(msg.data)

    def mobile_net_callback(self, msg):
        for detection in msg.deteccoes:
            classe = detection.classe.lower()  # Classe do objeto detectado
            if classe in self.creepers:
                # Salva a posição atual do robô
                self.creepers[classe] = (self.x, self.y)
                print(f"Objeto '{classe}' detectado! Posição salva: ({self.x:.2f}, {self.y:.2f})")

    def aruco_callback(self, msg):
        for detection in msg.deteccoes:
            aruco_id = detection.classe
            if self.detected_once == 0 and int(aruco_id[2]) == 0:
                self.aruco_detected_time = time.time()
                self.should_turn = True
                self.detected_once = 1
                print("Aruco detectado. Tempo registrado.")

    def creeper_callback(self, msg):
        # Inicializa um conjunto para rastrear os creepers detectados nesta execução
        detected_creepers = set()

        # Itera sobre as detecções recebidas
        for detection in msg.deteccoes:
            if '-' in detection.classe:
                try:
                    cor_id = detection.classe.split('-')
                    cor, id_ = cor_id[0], int(cor_id[1])
                    if id_ == 0:  # Ignora creepers com ID 0
                        print(f"Ignorando creeper com ID 0: {detection.classe}")
                        continue
                    creeper_key = f"{cor}_{id_}"
                    if creeper_key in self.creepers:  # Verifica se o creeper está na lista inicial
                        self.creepers[creeper_key] = 'creeper_place'
                        detected_creepers.add(creeper_key)  # Marca como detectado
                        print(f"Creeper detectado: {creeper_key} -> Atualizado para 'creeper_place'")
                    else:
                        print(f"Ignorando creeper desconhecido: {creeper_key}")
                except (ValueError, IndexError):
                    print(f"Erro ao processar creeper: {detection.classe}")

        # Atualiza apenas os creepers que não foram detectados nesta execução
        for creeper_key in self.creepers.keys():
            if creeper_key not in detected_creepers and self.creepers[creeper_key] == '':
                self.creepers[creeper_key] = 'labirinto'
                print(f"Creeper não detectado: {creeper_key} -> Atualizado para 'labirinto'")

        # Imprime o estado final dos creepers para depuração
        print("Estado final dos creepers:", self.creepers)

        
        

    
    def virar_esquerda(self):
        self.twist.angular.z = 0.2
        erro = self.goal_yaw - self.yaw
        erro = np.arctan2(np.sin(erro), np.cos(erro))
        if abs(erro) <= np.deg2rad(2):
            self.twist = Twist()
            self.goal_yaw = self.yaw + np.pi 
            self.robot_state = 'segue'
    

    def virar(self):
        self.twist.angular.z = -0.2
        erro = self.goal_yaw - self.yaw
        erro = np.arctan2(np.sin(erro), np.cos(erro))
        if abs(erro) <= np.deg2rad(2):
            self.twist = Twist()
            self.goal_yaw = self.yaw - np.pi
            self.robot_state = 'virar_esquerda'
            self.goal_yaw = self.yaw + np.pi / 2

    def image_callback(self, msg):
        if self.running:
            cv_image = self.bridge.compressed_imgmsg_to_cv2(msg, "bgr8")
            height, width, _ = cv_image.shape
            self.w = width // 2

            imagem_hsv = cv2.cvtColor(cv_image, cv2.COLOR_BGR2HSV)
            lower_yellow = np.array([20, 100, 100])
            upper_yellow = np.array([30, 255, 255])
            mask_hsv = cv2.inRange(imagem_hsv, lower_yellow, upper_yellow)
            mask = cv2.morphologyEx(mask_hsv, cv2.MORPH_OPEN, self.kernel)
            mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, self.kernel)
            contornos, _ = cv2.findContours(mask.copy(), cv2.RETR_TREE, cv2.CHAIN_APPROX_NONE)
            if contornos:
                largest_contour = max(contornos, key=cv2.contourArea)
                M = cv2.moments(largest_contour)
                if M["m00"] != 0:
                    self.cx = int(M["m10"] / M["m00"])
                    self.cy = int(M["m01"] / M["m00"])
                    cv_image = cv2.drawContours(cv_image, [largest_contour], -1, (0, 255, 0), 3)
                else:
                    self.cx = -1
            else:
                self.cx = -1

            cv2.imshow('Linha Amarela', cv_image)
            cv2.waitKey(1)

    def para(self):
        self.twist.linear.x = 0.0
        self.twist.angular.z = 0.0

    def centraliza(self):
        if self.cx >= 0:
            error = self.w - self.cx
            self.twist.angular.z = 0.003 * error
            self.twist.linear.x = 0.1
            if abs(error) < 15:
                self.robot_state = 'segue'
        else:
            self.twist.angular.z = 0.1
            self.twist.linear.x = 0.0

    def segue(self):
        self.twist.linear.x = 0.2
        elapsed_time = time.time() - self.start_time
        if elapsed_time >= 325:  # 5 minutos
            self.robot_state = 'para'
        
        elif self.cx >= 0:
            error = self.w - self.cx
            self.twist.angular.z = 0.003 * error
            if self.should_turn and self.aruco_detected_time:
                diferenca_tempo = time.time() - self.aruco_detected_time
                if diferenca_tempo >= 11:
                    self.ja_virou += 1
                    self.twist = Twist()
                    self.robot_state = 'virar'
                    self.goal_yaw = self.yaw - np.pi / 2
                    self.should_turn = False

        else:
            self.twist.angular.z = 0.1
            self.twist.linear.x = 0.0

    def control(self):
        self.twist = Twist()
        print(f'Estado Atual: {self.robot_state}')
        self.state_machine[self.robot_state]()
        self.cmd_vel_pub.publish(self.twist)

def main(args=None):
    rclpy.init(args=args)
    ros_node = SeguidorNode()
    rclpy.spin(ros_node)
    ros_node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
